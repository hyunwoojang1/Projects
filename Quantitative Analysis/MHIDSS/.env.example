# ── FRED API ─────────────────────────────────────────────────────────────────
FRED_API_KEY=ce2a6d19536c360259811d013ad1cfd0         # https://fred.stlouisfed.org/docs/api/api_key.html

# ── WRDS ─────────────────────────────────────────────────────────────────────
WRDS_USERNAME=hyunwoojang99
WRDS_PASSWORD=your_wrds_password            # 기관 구독 필요: https://wrds-www.wharton.upenn.edu/

# ── 가격 데이터 소스 ─────────────────────────────────────────────────────────
PRICE_DATA_SOURCE=yfinance                  # yfinance | alpaca | polygon
PRICE_DATA_API_KEY=                         # alpaca 또는 polygon 사용 시 필요

# ── 캐시 설정 ────────────────────────────────────────────────────────────────
CACHE_DIR=./data/.cache
CACHE_TTL_HOURS_FRED=24
CACHE_TTL_HOURS_WRDS=168
CACHE_TTL_HOURS_TECHNICAL=4

# ── 출력 설정 ────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
OUTPUT_FORMAT=json,html                     # json | csv | html (콤마 구분)

# ── 정규화 설정 ──────────────────────────────────────────────────────────────
NORMALIZATION_WINDOW_YEARS=10

# ── 시그널 임계값 ────────────────────────────────────────────────────────────
SIGNAL_THRESHOLD_STRONG_BUY=70
SIGNAL_THRESHOLD_BUY=55
SIGNAL_THRESHOLD_NEUTRAL=45
SIGNAL_THRESHOLD_SELL=30

# ── 로깅 ─────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text                             # text | json
